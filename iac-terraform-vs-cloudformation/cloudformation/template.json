{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "SRE IaC Project - Base VPC Infrastructure",
  "Resources": {
    "SreVpc": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsHostnames": true,
        "Tags": [
          {
            "Key": "Name",
            "Value": "sre-cloudformation-vpc"
          }
        ]
      }
    },
    "SreInternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [
          {
            "Key": "Name",
            "Value": "sre-igw"
          }
        ]
      }
    },
    "VpcGatewayAttachment": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": {
          "Ref": "SreVpc"
        },
        "InternetGatewayId": {
          "Ref": "SreInternetGateway"
        }
      }
    },
    "SrePublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": {
          "Ref": "SreVpc"
        },
        "CidrBlock": "10.0.1.0/24",
        "MapPublicIpOnLaunch": true,
        "AvailabilityZone": "us-east-1a",
        "Tags": [
          {
            "Key": "Name",
            "Value": "sre-public-subnet"
          }
        ]
      }
    }
  }
}