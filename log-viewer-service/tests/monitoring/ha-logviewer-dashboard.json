{
  "id": null,
  "uid": null,
  "title": "HA Log Viewer Observability",
  "tags": ["starter", "metrics"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pod CPU Usage (cores)",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"web-ha\",container!=\"\"}[2m])",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pod Memory Usage (bytes)",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace=\"web-ha\",container!=\"\"}",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "App Requests per Second",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"ha-logviewer\"}[1m])",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "App Error Rate (5xx)",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"ha-logviewer\",status=~\"5..\"}[1m])",
          "legendFormat": "errors/sec"
        }
      ]
    },
    {
    "id": 5,
    "type": "timeseries",
    "title": "App CPU Usage (per second)",
    "datasource": "prometheus",
    "targets": [
        {
        "expr": "rate(process_cpu_user_seconds_total{job=\"ha-logviewer\"}[1m])",
        "legendFormat": "{{instance}} user"
        },
        {
        "expr": "rate(process_cpu_system_seconds_total{job=\"ha-logviewer\"}[1m])",
        "legendFormat": "{{instance}} system"
        }
    ]
    },
    {
    "id": 6,
    "type": "timeseries",
    "title": "App Memory Usage (MB)",
    "datasource": "prometheus",
    "targets": [
        {
        "expr": "process_resident_memory_bytes{job=\"ha-logviewer\"} / 1024 / 1024",
        "legendFormat": "{{instance}}"
        }
    ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m"] }
}
